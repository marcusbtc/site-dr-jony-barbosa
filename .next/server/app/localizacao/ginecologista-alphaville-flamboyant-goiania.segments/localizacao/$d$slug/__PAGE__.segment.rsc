c:T4fa,{"@context":"https://schema.org","@type":["MedicalBusiness","Gynecologic","Obstetric"],"name":"Dr. Jony Barbosa - Ginecologista no Alphaville Flamboyant em Goiânia","url":"https://drjonybarbosa.com.br/localizacao/ginecologista-alphaville-flamboyant-goiania","telephone":"(62) 3070-5555","address":{"@type":"PostalAddress","streetAddress":"Edificio Absolut Business Style - Av. T-4, 1478 - 2 Andar - St. Bueno","addressLocality":"Goiânia","addressRegion":"GO","postalCode":"74230-030","addressCountry":"BR"},"geo":{"@type":"GeoCoordinates","latitude":-16.7028135,"longitude":-49.2676839},"areaServed":[{"@type":"City","name":"Goiânia"},{"@type":"Neighborhood","name":"Alphaville Flamboyant"}],"medicalSpecialty":["Gynecology","Obstetrics"],"availableService":[{"@type":"MedicalTherapy","name":"Obstetrícia","url":"https://drjonybarbosa.com.br/especialidades/obstetricia-goiania"},{"@type":"MedicalTherapy","name":"Gestação de Alto Risco","url":"https://drjonybarbosa.com.br/especialidades/gestacao-alto-risco-goiania"},{"@type":"MedicalTherapy","name":"Medicina Fetal","url":"https://drjonybarbosa.com.br/especialidades/medicina-fetal-goiania"},{"@type":"MedicalTherapy","name":"Consulta Médica","url":"https://drjonybarbosa.com.br/servicos/consulta-medica-goiania"}]}d:T644,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Onde o Dr. Jony atende pacientes do Alphaville Flamboyant?","acceptedAnswer":{"@type":"Answer","text":"As pacientes do Alphaville Flamboyant são atendidas em FetalCenter Goiânia, no endereço Edificio Absolut Business Style - Av. T-4, 1478 - 2 Andar - St. Bueno, Goiânia - GO, 74230-030. A equipe envia a melhor orientação de chegada no momento do agendamento."}},{"@type":"Question","name":"Quais atendimentos costumam ser mais procurados por quem mora no Alphaville Flamboyant?","acceptedAnswer":{"@type":"Answer","text":"Entre os atendimentos mais buscados por pacientes do Alphaville Flamboyant estão Obstetrícia, Gestação de Alto Risco, Medicina Fetal. A indicação ideal depende da sua fase de vida, sintomas, exames prévios e objetivos do tratamento."}},{"@type":"Question","name":"Como funciona o agendamento para pacientes do Alphaville Flamboyant?","acceptedAnswer":{"@type":"Answer","text":"O agendamento é feito de forma particular pelo WhatsApp. Depois do primeiro contato, a equipe orienta sobre horários, documentos, preparo quando houver exame e qual clínica faz mais sentido para o seu caso."}},{"@type":"Question","name":"Quem mora no Alphaville Flamboyant pode fazer acompanhamento completo com o Dr. Jony?","acceptedAnswer":{"@type":"Answer","text":"Sim. O atendimento cobre consulta ginecológica, pré-natal, medicina fetal, ultrassonografia e procedimentos conforme indicação clínica. Quando necessário, o cuidado continua com retornos e planejamento do tratamento."}}]}7:["$","main",null,{"className":"page-main flex-grow","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Início\",\"item\":\"https://drjonybarbosa.com.br\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Localização\",\"item\":\"https://drjonybarbosa.com.br/localizacao\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Alphaville Flamboyant\",\"item\":\"https://drjonybarbosa.com.br/localizacao/ginecologista-alphaville-flamboyant-goiania\"}]}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$c"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$d"}}],"$Le","$Lf","$L10","$L11","$L12","$L13","$L14","$L15","$L16"]}]
