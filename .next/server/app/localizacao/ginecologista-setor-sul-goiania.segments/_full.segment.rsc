15:T4a3,{"@context":"https://schema.org","@type":["MedicalBusiness","Gynecologic","Obstetric"],"name":"Dr. Jony Barbosa - Ginecologista no Setor Sul em Goiânia","url":"https://drjonybarbosa.com.br/localizacao/ginecologista-setor-sul-goiania","telephone":"(62) 99613-6640","address":{"@type":"PostalAddress","streetAddress":"R. 3A, 211 - St. Oeste","addressLocality":"Goiânia","addressRegion":"GO","postalCode":"74075-090","addressCountry":"BR"},"geo":{"@type":"GeoCoordinates","latitude":-16.678537,"longitude":-49.269218},"areaServed":[{"@type":"City","name":"Goiânia"},{"@type":"Neighborhood","name":"Setor Sul"}],"medicalSpecialty":["Gynecology","Obstetrics"],"availableService":[{"@type":"MedicalTherapy","name":"Ginecologia","url":"https://drjonybarbosa.com.br/especialidades/ginecologia-goiania"},{"@type":"MedicalTherapy","name":"Consulta Médica","url":"https://drjonybarbosa.com.br/servicos/consulta-medica-goiania"},{"@type":"MedicalTherapy","name":"Cirurgia Ginecológica","url":"https://drjonybarbosa.com.br/servicos/cirurgia-ginecologica-goiania"},{"@type":"MedicalTherapy","name":"Ultrassonografia","url":"https://drjonybarbosa.com.br/especialidades/ultrassonografia-goiania"}]}16:T5ce,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Onde o Dr. Jony atende pacientes do Setor Sul?","acceptedAnswer":{"@type":"Answer","text":"As pacientes do Setor Sul são atendidas em Policlínica São Luiz, no endereço R. 3A, 211 - St. Oeste, Goiânia - GO, 74075-090. A equipe envia a melhor orientação de chegada no momento do agendamento."}},{"@type":"Question","name":"Quais atendimentos costumam ser mais procurados por quem mora no Setor Sul?","acceptedAnswer":{"@type":"Answer","text":"Entre os atendimentos mais buscados por pacientes do Setor Sul estão Ginecologia, Consulta Médica, Cirurgia Ginecológica. A indicação ideal depende da sua fase de vida, sintomas, exames prévios e objetivos do tratamento."}},{"@type":"Question","name":"Como funciona o agendamento para pacientes do Setor Sul?","acceptedAnswer":{"@type":"Answer","text":"O agendamento é feito de forma particular pelo WhatsApp. Depois do primeiro contato, a equipe orienta sobre horários, documentos, preparo quando houver exame e qual clínica faz mais sentido para o seu caso."}},{"@type":"Question","name":"Quem mora no Setor Sul pode fazer acompanhamento completo com o Dr. Jony?","acceptedAnswer":{"@type":"Answer","text":"Sim. O atendimento cobre consulta ginecológica, pré-natal, medicina fetal, ultrassonografia e procedimentos conforme indicação clínica. Quando necessário, o cuidado continua com retornos e planejamento do tratamento."}}]}12:["$","main",null,{"className":"page-main flex-grow","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Início\",\"item\":\"https://drjonybarbosa.com.br\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Localização\",\"item\":\"https://drjonybarbosa.com.br/localizacao\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Setor Sul\",\"item\":\"https://drjonybarbosa.com.br/localizacao/ginecologista-setor-sul-goiania\"}]}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$15"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$16"}}],"$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f"]}]
