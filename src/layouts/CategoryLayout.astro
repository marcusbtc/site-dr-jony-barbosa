---
import type { ServiceCategory, ExtendedServiceItem } from '../types';
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';

interface Props {
  category: ServiceCategory;
  services: ExtendedServiceItem[];
}

const { category, services } = Astro.props;

const breadcrumbItems = [
  { label: 'Início', href: '/' },
  { label: category.name, href: `/${category.slug}` }
];

const whatsappUrl = 'https://wa.me/556299504788?text=Olá! Gostaria de agendar uma consulta';

const schemaMarkup = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `Especialidades e Serviços: ${category.name}`,
  "description": category.description,
  "itemListElement": services.map((service, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "url": `https://drjonybarbosa.com.br/${category.slug}/${service.slug}`,
    "name": service.title
  }))
};
---

<BaseLayout
  title={category.metaTitle}
  description={category.metaDescription}
  canonicalUrl={`https://drjonybarbosa.com.br/${category.slug}`}
>
  <!-- SEO: Inject Schema for category items -->
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(schemaMarkup)}></script>

  <Header />

  <main class="min-h-screen pt-24">
    <div class="container mx-auto px-6 lg:px-12 max-w-7xl pt-4">
      <Breadcrumbs items={breadcrumbItems} />
    </div>

    <!-- Hero Section -->
    <section class="bg-primary text-white py-16 lg:py-24 text-center mt-6">
      <div class="container mx-auto px-6 lg:px-12 max-w-7xl">
        <h1 class="text-4xl lg:text-5xl font-serif font-bold mb-6">{category.name}</h1>
        <p class="text-lg lg:text-xl font-light leading-relaxed max-w-4xl mx-auto opacity-95">
          {category.description}
        </p>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="py-20 lg:py-28 bg-white">
      <div class="container mx-auto px-6 lg:px-12 max-w-7xl">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {services.map(service => (
            <Card
              title={service.title}
              description={service.description}
              href={`/${category.slug}/${service.slug}`}
              linkText="Saiba Mais"
            />
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 lg:py-28 bg-slate-50 text-center">
      <div class="container mx-auto px-6 lg:px-12 max-w-7xl">
        <h2 class="text-3xl lg:text-4xl font-serif font-bold text-primary mb-6">Tem dúvidas?</h2>
        <div class="h-px bg-secondary/30 w-16 mx-auto mb-6"></div>
        <p class="text-lg lg:text-xl text-slate-600 mb-10 max-w-2xl mx-auto font-light">
          Agende uma consulta com Dr. Jony Barbosa e receba orientação personalizada e acolhimento humano.
        </p>
        <Button variant="primary" href={whatsappUrl} class="px-10 py-4 shadow-lg">
          Agendar Consulta
        </Button>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
