---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import HeroSection from '../components/HeroSection.astro';
import IntroSection from '../components/IntroSection.astro';
import CategoriesSection from '../components/CategoriesSection.astro';
import ServicesSection from '../components/ServicesSection.astro';
import PrenatalHighlight from '../components/PrenatalHighlight.astro';
import ExamsSection from '../components/ExamsSection.astro';
import AboutDoctor from '../components/AboutDoctor.astro';
import ProceduresSection from '../components/ProceduresSection.astro';
import WhyChooseSection from '../components/WhyChooseSection.astro';
import VideoSection from '../components/VideoSection.astro';
import FaqSection from '../components/FaqSection.astro';
import CtaSection from '../components/CtaSection.astro';
import BlogTeaser from '../components/BlogTeaser.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <div class="min-h-screen flex flex-col font-sans text-slate-600">
    <Header />
    <HeroSection />
    <IntroSection />
    <CategoriesSection />
    <AboutDoctor />
    <ServicesSection />
    <PrenatalHighlight />
    <ExamsSection />
    <ProceduresSection />
    <WhyChooseSection />
    <VideoSection />
    <FaqSection />
    <CtaSection />
    <BlogTeaser />
    <Footer />
  </div>
</BaseLayout>
