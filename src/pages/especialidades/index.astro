---
import CategoryLayout from '../../layouts/CategoryLayout.astro';
import { serviceCategories } from '../../data/categories';
import { getAllServicesByCategory } from '../../data/services-extended';

const category = serviceCategories.find(cat => cat.slug === 'especialidades');
if (!category) throw new Error('Categoria especialidades não encontrada');

const services = getAllServicesByCategory('especialidades');
---

<CategoryLayout category={category} services={services} />
