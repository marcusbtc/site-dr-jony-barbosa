---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import Button from '../components/ui/Button.astro';

const breadcrumbItems = [
  { label: 'Início', href: '/' },
  { label: 'Contato', href: '/contato' }
];
---

<BaseLayout
  title="Contato | Dr. Jony Barbosa - Ginecologista e Obstetra em Goiânia"
  description="Entre em contato com Dr. Jony Barbosa. Agende sua consulta pelo WhatsApp ou telefone. Atendimento em Goiânia com hora marcada."
  canonicalUrl="https://drjonybarbosa.com.br/contato"
>
  <Header />

  <main class="min-h-screen">
    <div class="mx-auto px-6 lg:px-12 max-w-7xl pt-20 lg:pt-24 pb-0">
      <Breadcrumbs items={breadcrumbItems} />
    </div>

    <!-- Hero -->
    <section class="contact-hero">
      <div class="container">
        <h1 class="hero-title">Entre em Contato</h1>
        <p class="hero-subtitle">
          Agende sua consulta e tire suas dúvidas com Dr. Jony Barbosa
        </p>
      </div>
    </section>

    <!-- Contact Info -->
    <section class="contact-section">
      <div class="container">
        <div class="contact-grid">
          <!-- Contact Cards -->
          <div class="contact-cards">
            <!-- WhatsApp -->
            <div class="contact-card featured">
              <div class="card-icon whatsapp">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
                </svg>
              </div>
              <h3 class="card-title">WhatsApp - Agendamento Rápido</h3>
              <p class="card-description">
                A forma mais rápida de agendar sua consulta
              </p>
              <a href="https://wa.me/556299504788?text=Olá! Gostaria de agendar uma consulta com Dr. Jony Barbosa" class="card-link">
                (62) 99950-4788
              </a>
              <Button variant="primary" href="https://wa.me/556299504788?text=Olá! Gostaria de agendar uma consulta com Dr. Jony Barbosa" class="mt-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block mr-2">
                  <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
                </svg>
                Agendar pelo WhatsApp
              </Button>
            </div>

            <!-- Telefone -->
            <div class="contact-card">
              <div class="card-icon phone">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
              </div>
              <h3 class="card-title">Telefone</h3>
              <p class="card-description">
                Ligue para agendar ou tirar dúvidas
              </p>
              <a href="tel:+556299504788" class="card-link">
                (62) 99950-4788
              </a>
            </div>

            <!-- Endereço -->
            <div class="contact-card">
              <div class="card-icon location">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
              </div>
              <h3 class="card-title">Localização</h3>
              <p class="card-description">
                FetalCenter Medicina Fetal<br/>
                Goiânia - GO
              </p>
              <p class="text-sm text-slate-500 mt-2">
                Consultório com hora marcada
              </p>
            </div>

            <!-- Horários -->
            <div class="contact-card">
              <div class="card-icon clock">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/>
                  <polyline points="12 6 12 12 16 14"/>
                </svg>
              </div>
              <h3 class="card-title">Horário de Atendimento</h3>
              <p class="card-description">
                Segunda a Sexta: 9h às 17h<br/>
                Sábados: Sob consulta
              </p>
              <p class="text-sm text-slate-500 mt-2">
                Atendimento por agendamento
              </p>
            </div>
          </div>

          <!-- Info Box -->
          <div class="info-box">
            <h2 class="info-title">Como Funciona o Atendimento</h2>

            <div class="info-steps">
              <div class="step">
                <div class="step-number">1</div>
                <div class="step-content">
                  <h3 class="step-title">Agende pelo WhatsApp</h3>
                  <p class="step-description">
                    Entre em contato pelo WhatsApp e escolha o melhor dia e horário para sua consulta.
                  </p>
                </div>
              </div>

              <div class="step">
                <div class="step-number">2</div>
                <div class="step-content">
                  <h3 class="step-title">Confirmação</h3>
                  <p class="step-description">
                    Nossa equipe confirmará sua consulta e enviará todas as informações necessárias.
                  </p>
                </div>
              </div>

              <div class="step">
                <div class="step-number">3</div>
                <div class="step-content">
                  <h3 class="step-title">Atendimento Personalizado</h3>
                  <p class="step-description">
                    Você será atendida com tempo adequado, atenção e cuidado humanizado pelo Dr. Jony.
                  </p>
                </div>
              </div>
            </div>

            <div class="info-highlight">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="highlight-icon">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
              <div>
                <h4 class="highlight-title">Atendimento Particular e Convênios</h4>
                <p class="highlight-text">
                  Aceitamos os principais convênios médicos de Goiânia. Fornecemos documentação completa para reembolso.
                  Entre em contato para confirmar seu convênio.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="faq-section">
      <div class="container">
        <h2 class="section-title">Perguntas Frequentes sobre Agendamento</h2>

        <div class="faq-grid">
          <div class="faq-item">
            <h3 class="faq-question">Preciso de pedido médico para agendar?</h3>
            <p class="faq-answer">
              Não é necessário pedido médico para consultas ginecológicas ou pré-natal. Para exames específicos,
              entre em contato para confirmar.
            </p>
          </div>

          <div class="faq-item">
            <h3 class="faq-question">Quanto tempo dura a consulta?</h3>
            <p class="faq-answer">
              As consultas têm duração de 40 a 60 minutos, garantindo tempo adequado para avaliação,
              exame físico quando necessário e esclarecimento de todas as suas dúvidas.
            </p>
          </div>

          <div class="faq-item">
            <h3 class="faq-question">Posso levar acompanhante?</h3>
            <p class="faq-answer">
              Sim! Você pode levar um acompanhante para a consulta, especialmente em consultas de pré-natal
              onde o parceiro é muito bem-vindo.
            </p>
          </div>

          <div class="faq-item">
            <h3 class="faq-question">Como funciona o reembolso de convênio?</h3>
            <p class="faq-answer">
              Fornecemos toda a documentação necessária (recibo, relatório médico) para solicitação de reembolso
              junto ao seu convênio. O processo varia conforme cada operadora.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Hero Section */
  .contact-hero {
    background: #1e4d7b;
    color: white;
    padding: 1.5rem 1.5rem 2.5rem;
    text-align: center;
  }

  .hero-title {
    font-family: 'Playfair Display', serif;
    font-size: 3rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    opacity: 0.95;
  }

  /* Contact Section */
  .contact-section {
    padding: 4rem 1.5rem;
    background: white;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .contact-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .contact-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .contact-card {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 1rem;
    padding: 2rem;
    text-align: center;
    transition: all 0.3s ease;
  }

  .contact-card:hover {
    border-color: #4fb3bf;
    box-shadow: 0 8px 24px rgba(30, 77, 123, 0.1);
    transform: translateY(-4px);
  }

  .contact-card.featured {
    grid-column: 1 / -1;
    background: linear-gradient(135deg, #f8fafc 0%, #e0f2f1 100%);
    border-color: #4fb3bf;
  }

  .card-icon {
    width: 4rem;
    height: 4rem;
    margin: 0 auto 1.5rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-icon.whatsapp {
    background: #25d366;
    color: white;
  }

  .card-icon.phone {
    background: #1e4d7b;
    color: white;
  }

  .card-icon.location {
    background: #4fb3bf;
    color: white;
  }

  .card-icon.clock {
    background: #64748b;
    color: white;
  }

  .card-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1e4d7b;
    margin-bottom: 0.5rem;
  }

  .card-description {
    color: #64748b;
    margin-bottom: 1rem;
    font-size: 0.9375rem;
  }

  .card-link {
    display: inline-block;
    color: #1e4d7b;
    font-weight: 600;
    font-size: 1.25rem;
    text-decoration: none;
    transition: color 0.3s;
  }

  .card-link:hover {
    color: #4fb3bf;
  }

  /* Info Box */
  .info-box {
    background: #f8fafc;
    border-radius: 1rem;
    padding: 2.5rem;
    border: 1px solid #e2e8f0;
  }

  .info-title {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    font-weight: 700;
    color: #1e4d7b;
    margin-bottom: 2rem;
  }

  .info-steps {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .step {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .step-number {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: linear-gradient(135deg, #4fb3bf 0%, #1e4d7b 100%);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .step-content {
    flex: 1;
  }

  .step-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: #1e4d7b;
    margin-bottom: 0.5rem;
  }

  .step-description {
    color: #64748b;
    line-height: 1.6;
  }

  .info-highlight {
    background: white;
    border-left: 4px solid #4fb3bf;
    padding: 1.5rem;
    border-radius: 0.5rem;
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .highlight-icon {
    color: #4fb3bf;
    flex-shrink: 0;
  }

  .highlight-title {
    font-weight: 600;
    color: #1e4d7b;
    margin-bottom: 0.5rem;
  }

  .highlight-text {
    color: #64748b;
    line-height: 1.6;
    font-size: 0.9375rem;
  }

  /* FAQ Section */
  .faq-section {
    padding: 4rem 1.5rem;
    background: #f8fafc;
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: #1e4d7b;
    text-align: center;
    margin-bottom: 3rem;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .faq-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .faq-item {
    background: white;
    border-radius: 0.75rem;
    padding: 1.5rem;
    border: 1px solid #e2e8f0;
  }

  .faq-question {
    font-weight: 600;
    color: #1e4d7b;
    margin-bottom: 0.75rem;
    font-size: 1.0625rem;
  }

  .faq-answer {
    color: #64748b;
    line-height: 1.6;
    font-size: 0.9375rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero-title {
      font-size: 2.25rem;
    }

    .contact-hero {
      padding: 3rem 1.5rem 2rem;
    }

    .info-title {
      font-size: 1.75rem;
    }

    .section-title {
      font-size: 2rem;
    }
  }
</style>
