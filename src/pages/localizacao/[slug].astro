---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import LocalSchema from '../../components/seo/LocalSchema.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import Button from '../../components/ui/Button.astro';
import WhyChooseSection from '../../components/WhyChooseSection.astro';
import ServicesSection from '../../components/ServicesSection.astro';
import CategoriesSection from '../../components/CategoriesSection.astro';
import PrenatalHighlight from '../../components/PrenatalHighlight.astro';
import ExamsSection from '../../components/ExamsSection.astro';
import ProceduresSection from '../../components/ProceduresSection.astro';
import AboutDoctor from '../../components/AboutDoctor.astro';
import FaqSection from '../../components/FaqSection.astro';
import CtaSection from '../../components/CtaSection.astro';
import { nobleNeighborhoods, type NeighborhoodData } from '../../data/neighborhoods';

export const getStaticPaths = (() => {
  return nobleNeighborhoods.map((neighborhood) => ({
    params: { slug: neighborhood.slug },
    props: { neighborhood }
  }));
}) satisfies GetStaticPaths;

interface Props {
  neighborhood: NeighborhoodData;
}

const { neighborhood } = Astro.props;

const breadcrumbItems = [
  { label: 'Início', href: '/' },
  { label: 'Localização', href: '#' },
  { label: neighborhood.name, href: `/localizacao/${neighborhood.slug}` }
];

// Localized SEO Meta
const title = `Ginecologista e Obstetra no ${neighborhood.name} - Goiânia | Dr. Jony Barbosa`;
const description = `Dr. Jony Barbosa: Atendimento premium em Ginecologia e Obstetrícia no ${neighborhood.name}, Goiânia. Agende sua consulta. ${neighborhood.description.substring(0, 80)}...`;
const canonicalUrl = `https://drjonybarbosa.com.br/localizacao/${neighborhood.slug}`;
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
>
  <LocalSchema slot="head" neighborhoodName={neighborhood.name} url={canonicalUrl} clinic={neighborhood.clinic} />
  
  <div class="min-h-screen flex flex-col font-sans text-slate-600">
    <Header />
    
    <div class="mx-auto px-6 lg:px-12 max-w-7xl pt-[90px] pb-2">
      <Breadcrumbs items={breadcrumbItems} />
    </div>

    <!-- Localized Hero Section -->
    <section class="pt-8 pb-16 lg:pt-12 lg:pb-20 bg-slate-50 relative overflow-hidden border-b border-slate-200">
      <div class="absolute inset-0 bg-[url('/grid-pattern.svg')] opacity-5"></div>
      
      <div class="container mx-auto px-6 lg:px-12 max-w-7xl relative z-10">
        <div class="flex flex-col lg:flex-row items-center gap-12">
          <div class="lg:w-3/5 space-y-8 relative z-20">
            <div class="space-y-4">
              <span class="text-sm font-bold tracking-wider text-accent uppercase">Atendimento Premium em Goiânia</span>
              <h1 class="text-5xl lg:text-7xl font-serif font-bold text-primary leading-[1.1] tracking-tight">
                Ginecologista no <br/> <span class="text-secondary">{neighborhood.name}</span>
              </h1>
              <p class="text-xs text-secondary/70 uppercase tracking-[0.2em] font-bold">
                Dr. Jony Barbosa | CRM 7652 | RQE 3900 | RQE 9229
              </p>
            </div>

            <div class="h-px bg-secondary/30 w-24"></div>

            <div class="prose prose-slate prose-lg max-w-none">
              <p class="text-xl text-slate-700 leading-relaxed font-light italic">
                "{neighborhood.description}"
              </p>
              <p class="text-lg text-slate-600 leading-relaxed">
                {neighborhood.localContext}
              </p>
            </div>

            <div class="flex flex-col sm:flex-row gap-4 pt-4">
              <Button variant="primary" href="#contato" class="text-base px-10 py-4 shadow-xl shadow-primary/20">
                Agendar Consulta
              </Button>
              <Button variant="outline" href="/especialidades" class="text-base px-10 py-4 border-slate-300 text-slate-600 hover:border-secondary">
                Ver Especialidades
              </Button>
            </div>
          </div>

          <div class="lg:w-2/5 relative">
            <div class="relative w-full max-w-md mx-auto">
              <div class="absolute inset-0 bg-primary rounded-2xl transform translate-x-4 translate-y-4"></div>
              
              <img
                src="/dr-jony-profile.webp"
                alt={`Dr. Jony Barbosa Ginecologista ${neighborhood.name} Goiânia`}
                width="504"
                height="619"
                class="w-full h-auto object-cover rounded-2xl shadow-lg relative z-10 border border-slate-200"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Context & Logistics Sections -->
    <section class="py-20 bg-white">
      <div class="container mx-auto px-6 lg:px-12 max-w-7xl">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
          <!-- Logistics Section -->
          <div class="space-y-8">
            <div class="inline-block p-3 rounded-xl bg-secondary/10 text-secondary mb-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <h2 class="text-3xl font-serif font-bold text-primary">Atendimento para Moradoras do {neighborhood.shortName}</h2>
            <div class="prose prose-slate prose-lg">
              <p>{neighborhood.logisticDetails}</p>
              <div class="mt-8 p-6 bg-slate-50 rounded-2xl border border-slate-100 space-y-4">
                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 rounded-full bg-white shadow-sm flex items-center justify-center text-secondary flex-shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  </div>
                  <div>
                    <h4 class="font-bold text-primary mb-1">Agendamento Facilitado</h4>
                    <p class="text-sm text-slate-500">Horários flexíveis via WhatsApp para conciliar com sua rotina no {neighborhood.shortName}.</p>
                  </div>
                </div>
                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 rounded-full bg-white shadow-sm flex items-center justify-center text-secondary flex-shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/></svg>
                  </div>
                  <div>
                    <h4 class="font-bold text-primary mb-1">Unidade de Atendimento</h4>
                    <p class="text-sm text-slate-500">{neighborhood.clinic.name} - {neighborhood.clinic.address}</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Health Tips Section -->
          <div class="space-y-8">
            <div class="inline-block p-3 rounded-xl bg-primary/10 text-primary mb-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
            </div>
            <h2 class="text-3xl font-serif font-bold text-primary">Saúde da Mulher no {neighborhood.shortName}</h2>
            <div class="prose prose-slate prose-lg">
              <p>{neighborhood.localCareTips}</p>
              <ul class="mt-6 space-y-3">
                <li class="flex items-center gap-3 text-slate-600">
                  <svg class="text-secondary" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  Medicina Fetal de Alta Precisão
                </li>
                <li class="flex items-center gap-3 text-slate-600">
                  <svg class="text-secondary" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  Acompanhamento Pré-natal Personalizado
                </li>
                <li class="flex items-center gap-3 text-slate-600">
                  <svg class="text-secondary" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  Ginecologia Preventiva e Regenerativa
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="relative z-20">
      <CategoriesSection 
        title={`Especialidades no ${neighborhood.shortName}`} 
        subtitle={`Atendimento especializado em Ginecologia e Obstetrícia para moradoras do ${neighborhood.name}`}
      />
    </div>

    <WhyChooseSection />
    
    <PrenatalHighlight />
    
    <ExamsSection />
    
    <ProceduresSection />
    
    <div class="bg-slate-50">
      <ServicesSection 
        title={`Serviços para o ${neighborhood.shortName}`}
        subtitle="Tecnologia e humanização no cuidado com sua saúde"
      />
    </div>
    
    <AboutDoctor />
    
    <section class="py-20 bg-white border-t border-slate-100">
      <div class="container mx-auto px-6 lg:px-12 max-w-7xl">
        <div class="text-center mb-12">
          <h2 class="text-3xl lg:text-4xl font-serif font-bold text-primary">Outras Regiões Atendidas</h2>
          <p class="text-slate-500 mt-4">Atendimento premium em diversos bairros nobres de Goiânia</p>
        </div>
        <div class="flex flex-wrap justify-center gap-4">
          {nobleNeighborhoods.filter(n => n.slug !== neighborhood.slug).map(n => (
            <a 
              href={`/localizacao/${n.slug}`}
              class="px-6 py-3 rounded-full border border-slate-200 text-slate-600 hover:border-secondary hover:text-secondary transition-all font-medium bg-white shadow-sm"
            >
              Ginecologista no {n.shortName}
            </a>
          ))}
        </div>
      </div>
    </section>

    <FaqSection />
    
    <CtaSection />
    
    <Footer />
  </div>
</BaseLayout>
