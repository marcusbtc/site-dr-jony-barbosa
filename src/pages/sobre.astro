---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';

const breadcrumbItems = [
  { label: 'Início', href: '/' },
  { label: 'Sobre', href: '/sobre' }
];
---

<BaseLayout
  title="Sobre Dr. Jony Barbosa | Ginecologista e Obstetra em Goiânia"
  description="Conheça Dr. Jony Rodrigues Barbosa, ginecologista, obstetra e especialista em medicina fetal. Formação no IFF/RJ, diretor do FetalCenter e mais de 5.000 pacientes atendidos."
  canonicalUrl="https://drjonybarbosa.com.br/sobre"
>
  <Header />

  <main class="min-h-screen">
    <div class="mx-auto px-6 lg:px-12 max-w-7xl pt-20 lg:pt-28 pb-4">
      <Breadcrumbs items={breadcrumbItems} />
    </div>

    <!-- Hero -->
    <section class="about-hero">
      <div class="container">
        <h1 class="hero-title">Dr. Jony Rodrigues Barbosa</h1>
        <p class="hero-subtitle">
          Ginecologista, Obstetra e Especialista em Medicina Fetal
        </p>
        <div class="hero-credentials">
          CRM 7652 | RQE Nº 3900 | RQE Nº 9229
        </div>
      </div>
    </section>

    <!-- Main Content -->
    <section class="about-content">
      <div class="container">
        <div class="content-grid">
          <!-- Image -->
          <div class="image-section">
            <img
              src="https://picsum.photos/id/338/600/700"
              alt="Dr. Jony Barbosa - Ginecologista e Obstetra em Goiânia"
              class="doctor-image"
            />
          </div>

          <!-- Text Content -->
          <div class="text-section">
            <div class="section-intro">
              <h2 class="section-title">Sobre o Profissional</h2>
              <div class="divider"></div>
            </div>

            <div class="text-content">
              <p>
                O <strong>Dr. Jony Rodrigues Barbosa</strong> é médico ginecologista, obstetra e especialista
                em medicina fetal, dedicado ao cuidado integral da saúde da mulher em todas as fases da vida.
              </p>

              <p>
                Graduado pela <strong>Universidade Federal de Goiás (UFG)</strong>, realizou especialização em
                Ginecologia e Obstetrícia no Hospital das Clínicas de Goiânia, uma das principais instituições
                de saúde do Centro-Oeste brasileiro.
              </p>

              <p>
                Buscando excelência em medicina fetal, completou formação avançada no renomado
                <strong>Instituto Fernandes Figueira (IFF/Fiocruz)</strong>, no Rio de Janeiro, referência
                nacional em medicina fetal, ultrassonografia obstétrica e diagnóstico pré-natal.
              </p>

              <p>
                Atualmente, é <strong>Diretor Técnico Médico do FetalCenter</strong>, clínica especializada
                em medicina fetal e ultrassonografia em Goiânia, equipada com tecnologia de ponta para
                diagnóstico e acompanhamento gestacional.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Experience -->
    <section class="experience-section">
      <div class="container">
        <div class="section-intro centered">
          <h2 class="section-title">Experiência Profissional</h2>
          <div class="divider centered"></div>
        </div>

        <div class="experience-grid">
          <div class="experience-card">
            <div class="card-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                <polyline points="9 22 9 12 15 12 15 22"/>
              </svg>
            </div>
            <h3 class="card-title">FetalCenter Goiânia</h3>
            <p class="card-role">Diretor Técnico Médico</p>
            <p class="card-description">
              Responsável pela direção técnica da clínica especializada em medicina fetal,
              garantindo qualidade, segurança e excelência nos exames e atendimentos.
            </p>
          </div>

          <div class="experience-card">
            <div class="card-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
                <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
              </svg>
            </div>
            <h3 class="card-title">Faculdade de Medicina PUC-Goiás</h3>
            <p class="card-role">Médico Preceptor de Estágio</p>
            <p class="card-description">
              Orientação e supervisão de acadêmicos de medicina em estágio de ginecologia
              e obstetrícia, contribuindo para a formação de novos médicos.
            </p>
          </div>

          <div class="experience-card">
            <div class="card-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
              </svg>
            </div>
            <h3 class="card-title">Maternidades Públicas de Goiânia</h3>
            <p class="card-role">Ginecologista e Obstetra</p>
            <p class="card-description">
              Atendimento em maternidades de referência: Maternidade Nascer Cidadão e
              Maternidade Dona Iris, ampla experiência com gestações de alto risco.
            </p>
          </div>

          <div class="experience-card">
            <div class="card-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </div>
            <h3 class="card-title">Consultório Particular</h3>
            <p class="card-role">Atendimento Privado</p>
            <p class="card-description">
              Atendimento personalizado e humanizado em consultório particular,
              com foco na saúde integral da mulher e medicina fetal de precisão.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Numbers -->
    <section class="numbers-section">
      <div class="container">
        <div class="numbers-grid">
          <div class="number-card">
            <div class="number">5.000+</div>
            <div class="number-label">Pacientes Atendidos</div>
          </div>

          <div class="number-card">
            <div class="number">IFF/RJ</div>
            <div class="number-label">Formação em Medicina Fetal</div>
          </div>

          <div class="number-card">
            <div class="number">UFG</div>
            <div class="number-label">Graduação em Medicina</div>
          </div>

          <div class="number-card">
            <div class="number">HC/GO</div>
            <div class="number-label">Residência Médica</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Values -->
    <section class="values-section">
      <div class="container">
        <div class="section-intro centered">
          <h2 class="section-title">Missão e Valores</h2>
          <div class="divider centered"></div>
          <p class="section-description">
            O compromisso com a saúde e bem-estar das pacientes guia cada atendimento
          </p>
        </div>

        <div class="values-grid">
          <div class="value-card">
            <div class="value-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </div>
            <h3 class="value-title">Humanização</h3>
            <p class="value-description">
              Atendimento acolhedor, empático e respeitoso, dedicando tempo para ouvir e esclarecer cada dúvida.
            </p>
          </div>

          <div class="value-card">
            <div class="value-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
              </svg>
            </div>
            <h3 class="value-title">Excelência Técnica</h3>
            <p class="value-description">
              Formação em instituições de referência e atualização constante para oferecer o melhor cuidado médico.
            </p>
          </div>

          <div class="value-card">
            <div class="value-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
                <line x1="12" y1="17" x2="12.01" y2="17"/>
              </svg>
            </div>
            <h3 class="value-title">Transparência</h3>
            <p class="value-description">
              Comunicação clara e acessível sobre diagnósticos, tratamentos e resultados de exames.
            </p>
          </div>

          <div class="value-card">
            <div class="value-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                <line x1="8" y1="21" x2="16" y2="21"/>
                <line x1="12" y1="17" x2="12" y2="21"/>
              </svg>
            </div>
            <h3 class="value-title">Tecnologia de Ponta</h3>
            <p class="value-description">
              Equipamentos modernos e tecnologia avançada para diagnósticos precisos e seguros.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Quote -->
    <section class="quote-section">
      <div class="container">
        <blockquote class="quote">
          <p class="quote-text">
            "Meu compromisso é oferecer um atendimento individualizado, com atenção humanizada,
            conhecimento técnico e equipamentos de ponta para cuidar da sua saúde e do seu bebê."
          </p>
          <footer class="quote-author">
            <strong>Dr. Jony Rodrigues Barbosa</strong>
            <span>CRM 7652</span>
          </footer>
        </blockquote>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Hero */
  .about-hero {
    background: #1e4d7b;
    color: white;
    padding: 3rem 1.5rem 3rem;
    text-align: center;
  }

  .hero-title {
    font-family: 'Playfair Display', serif;
    font-size: 3rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    opacity: 0.95;
    margin-bottom: 1rem;
  }

  .hero-credentials {
    font-size: 0.875rem;
    opacity: 0.85;
    letter-spacing: 0.05em;
  }

  /* About Content */
  .about-content {
    padding: 4rem 1.5rem;
    background: white;
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .content-grid {
      grid-template-columns: 5fr 7fr;
    }
  }

  .doctor-image {
    width: 100%;
    border-radius: 1rem;
    box-shadow: 0 8px 32px rgba(30, 77, 123, 0.15);
  }

  .section-intro {
    margin-bottom: 2rem;
  }

  .section-intro.centered {
    text-align: center;
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: #1e4d7b;
    margin-bottom: 1rem;
  }

  .divider {
    width: 4rem;
    height: 3px;
    background: linear-gradient(90deg, #4fb3bf 0%, #1e4d7b 100%);
    border-radius: 2px;
  }

  .divider.centered {
    margin: 0 auto;
  }

  .section-description {
    color: #64748b;
    font-size: 1.125rem;
    max-width: 600px;
    margin: 1rem auto 0;
  }

  .text-content {
    color: #64748b;
    font-size: 1.0625rem;
    line-height: 1.8;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .text-content strong {
    color: #1e4d7b;
    font-weight: 600;
  }

  /* Experience */
  .experience-section {
    padding: 4rem 1.5rem;
    background: #f8fafc;
  }

  .experience-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-top: 3rem;
  }

  @media (min-width: 768px) {
    .experience-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .experience-card {
    background: white;
    border-radius: 1rem;
    padding: 2rem;
    border: 1px solid #e2e8f0;
    transition: all 0.3s ease;
  }

  .experience-card:hover {
    border-color: #4fb3bf;
    box-shadow: 0 8px 24px rgba(30, 77, 123, 0.1);
    transform: translateY(-4px);
  }

  .card-icon {
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    background: linear-gradient(135deg, #4fb3bf 0%, #1e4d7b 100%);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
  }

  .card-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1e4d7b;
    margin-bottom: 0.5rem;
  }

  .card-role {
    font-size: 0.9375rem;
    color: #4fb3bf;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .card-description {
    color: #64748b;
    line-height: 1.6;
    font-size: 0.9375rem;
  }

  /* Numbers */
  .numbers-section {
    padding: 4rem 1.5rem;
    background: white;
  }

  .numbers-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .numbers-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .number-card {
    text-align: center;
    padding: 2rem 1rem;
    background: #f8fafc;
    border-radius: 0.75rem;
    border: 1px solid #e2e8f0;
  }

  .number {
    font-size: 2.5rem;
    font-weight: 700;
    color: #1e4d7b;
    margin-bottom: 0.5rem;
  }

  .number-label {
    color: #64748b;
    font-size: 0.875rem;
  }

  /* Values */
  .values-section {
    padding: 4rem 1.5rem;
    background: #f8fafc;
  }

  .values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-top: 3rem;
  }

  @media (min-width: 768px) {
    .values-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .values-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .value-card {
    background: white;
    border-radius: 0.75rem;
    padding: 2rem;
    text-align: center;
    border: 1px solid #e2e8f0;
    transition: all 0.3s ease;
  }

  .value-card:hover {
    border-color: #4fb3bf;
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(30, 77, 123, 0.1);
  }

  .value-icon {
    width: 3.5rem;
    height: 3.5rem;
    margin: 0 auto 1.5rem;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(79, 179, 191, 0.1) 0%, rgba(30, 77, 123, 0.1) 100%);
    color: #4fb3bf;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .value-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: #1e4d7b;
    margin-bottom: 0.75rem;
  }

  .value-description {
    color: #64748b;
    line-height: 1.6;
    font-size: 0.9375rem;
  }

  /* Quote */
  .quote-section {
    padding: 4rem 1.5rem;
    background: linear-gradient(135deg, #1e4d7b 0%, #1a3f63 100%);
    color: white;
  }

  .quote {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .quote-text {
    font-size: 1.5rem;
    font-style: italic;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .quote-author {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .quote-author strong {
    font-size: 1.125rem;
  }

  .quote-author span {
    font-size: 0.875rem;
    opacity: 0.8;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero-title {
      font-size: 2.25rem;
    }

    .section-title {
      font-size: 2rem;
    }

    .quote-text {
      font-size: 1.25rem;
    }
  }
</style>
