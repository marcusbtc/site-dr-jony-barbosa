---
import type { GetStaticPaths } from 'astro';
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import { servicesExtended } from '../../data/services-extended';

export const getStaticPaths = (() => {
  const exameServices = servicesExtended.filter(
    service => service.category === 'exame'
  );

  return exameServices.map(service => ({
    params: { slug: service.slug },
    props: { service, category: 'exames' }
  }));
}) satisfies GetStaticPaths;

const { service, category } = Astro.props;
---

<ServiceLayout service={service} category={category} />
