---
import Slider from './ui/Slider.astro';
import Card from './ui/Card.astro';
import Button from './ui/Button.astro';
import { servicesExtended } from '../data/services-extended';

interface Props {
  title?: string;
  subtitle?: string;
}

const { 
  title = "Especialidades",
  subtitle = "Cuidado Integral da Saúde Feminina"
} = Astro.props;

// Get all especialidades for homepage
const especialidades = servicesExtended.filter(s => s.category === 'especialidade');
---

<section id="servicos" class="py-24 lg:py-32 bg-white relative">
  <div class="container mx-auto px-6 lg:px-16 max-w-7xl">
    <Slider
      id="especialidades-slider"
      title={title}
      subtitle={subtitle}
    >
      {especialidades.map((service) => (
        <Card item={service} type="service" />
      ))}
    </Slider>

    <div class="text-center mt-12">
      <Button variant="primary" href="/especialidades">
        Ver Todas as Especialidades
      </Button>
    </div>
  </div>
</section>
