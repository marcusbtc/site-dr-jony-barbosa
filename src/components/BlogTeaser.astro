---
import Button from './ui/Button.astro';
import { blogPosts } from '../data/site-data';
---

<section class="py-20 bg-slate-50">
  <div class="container mx-auto px-6">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-serif text-primary">Blog Dr. Jony</h2>
    </div>
    <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      {blogPosts.map((post) => (
        <div class="bg-white p-8 rounded-xl shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
          <h3 class="text-xl font-bold text-primary mb-3 underline decoration-accent decoration-2">{post.title}</h3>
          <p class="text-slate-600 mb-4 text-sm">{post.excerpt}</p>
          <Button variant="primary" class="text-xs px-4 py-2">Ler mais</Button>
        </div>
      ))}
    </div>
  </div>
</section>
