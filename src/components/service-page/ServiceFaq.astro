---
import type { FaqItem } from '../../types';
import Accordion from '../Accordion';

interface Props {
  faqs: FaqItem[];
  serviceTitle: string;
}

const { faqs, serviceTitle } = Astro.props;
---

{faqs && faqs.length > 0 && (
  <section class="py-20 md:py-28 bg-slate-50">
    <div class="container mx-auto px-6 max-w-4xl">
      <h2 class="text-3xl md:text-4xl font-serif font-bold text-primary text-center mb-4">Perguntas Frequentes sobre {serviceTitle}</h2>
      <p class="text-lg text-slate-600 font-light text-center mb-12">
        Tire suas dúvidas sobre o procedimento
      </p>

      <div class="mt-8 bg-white p-8 rounded-2xl shadow-sm border border-slate-100">
        <Accordion items={faqs} client:visible />
      </div>
    </div>
  </section>
)}
