---
import type { ButtonVariant } from '../../types';

interface Props {
  variant?: ButtonVariant;
  href?: string;
  class?: string;
  type?: 'button' | 'submit' | 'reset';
}

const {
  variant = 'primary',
  href,
  class: className = '',
  type = 'button'
} = Astro.props;

const baseStyle = "px-6 py-3 rounded-lg font-medium transition-colors duration-200 inline-flex items-center gap-2 outline-hidden focus:ring-2 focus:ring-offset-2";

const variants: Record<ButtonVariant | 'outline-light', string> = {
  primary: "bg-primary text-white hover:bg-primary/90 focus:ring-primary shadow-sm",
  accent: "bg-secondary text-white hover:bg-secondary/90 focus:ring-secondary shadow-sm",
  outline: "border border-slate-300 text-slate-700 bg-white hover:bg-slate-50 focus:ring-slate-200 shadow-sm",
  "outline-light": "border border-white text-white bg-transparent hover:bg-white hover:text-primary focus:ring-white shadow-sm"
};

const combinedClass = `${baseStyle} ${variants[variant]} ${className}`;

const Tag = href ? 'a' : 'button';
---

<Tag
  class={combinedClass}
  href={href}
  type={!href ? type : undefined}
>
  <slot />
</Tag>
