---
import SectionTitle from './ui/SectionTitle.astro';
import Button from './ui/Button.astro';
---

<section class="pb-24 lg:pb-32 bg-slate-50 relative z-20">
  <div class="container mx-auto px-6 lg:px-12 max-w-7xl">
    <!-- Offset grid to overlap the Hero section above -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative -mt-16 lg:-mt-24">
      <!-- Especialidades -->
      <div class="bg-white p-8 rounded-xl border border-slate-200 hover:border-primary/30 shadow-sm hover:shadow-md transition-all duration-200 flex flex-col">
        <div class="text-secondary mb-6 bg-bgLight w-16 h-16 rounded-full flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:scale-110 transition-transform">
            <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
          </svg>
        </div>
        <h3 class="text-2xl font-serif font-bold text-primary mb-4">Especialidades</h3>
        <p class="text-slate-600/90 mb-8 leading-relaxed font-light">
          Gestação de alto risco, ginecologia, medicina fetal, obstetrícia e ultrassonografia com Dr. Jony Barbosa.
        </p>
        <ul class="text-sm text-slate-600 mb-8 space-y-3">
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 rounded-full bg-secondary"></div>
            <span>Gestação de Alto Risco</span>
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 rounded-full bg-secondary"></div>
            <span>Medicina Fetal</span>
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 rounded-full bg-secondary"></div>
            <span>Ginecologia e Obstetrícia</span>
          </li>
        </ul>
        <Button variant="primary" href="/especialidades" class="w-full justify-center">
          Ver Especialidades
        </Button>
      </div>

      <!-- Exames -->
      <div class="bg-white p-8 rounded-xl border border-slate-200 hover:border-primary/30 shadow-sm hover:shadow-md transition-all duration-200 flex flex-col">
        <div class="text-secondary mb-6 bg-bgLight w-16 h-16 rounded-full flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:scale-110 transition-transform">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10 9 9 9 8 9"/>
          </svg>
        </div>
        <h3 class="text-2xl font-serif font-bold text-primary mb-4">Exames</h3>
        <p class="text-slate-600/90 mb-8 leading-relaxed font-light">
          Exames especializados de medicina fetal e diagnóstico pré-natal com tecnologia de ponta.
        </p>
        <ul class="text-sm text-slate-600 mb-8 space-y-3">
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 rounded-full bg-secondary"></div>
            <span>NIPT e Amniocentese</span>
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 rounded-full bg-secondary"></div>
            <span>Ultrassom Morfológico</span>
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 rounded-full bg-secondary"></div>
            <span>Doppler e muito mais</span>
          </li>
        </ul>
        <Button variant="accent" href="/exames" class="w-full justify-center">
          Ver Exames
        </Button>
      </div>

      <!-- Serviços -->
      <div class="bg-white p-8 rounded-xl border border-slate-200 hover:border-primary/30 shadow-sm hover:shadow-md transition-all duration-200 flex flex-col">
        <div class="text-secondary mb-6 bg-bgLight w-16 h-16 rounded-full flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:scale-110 transition-transform">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
        </div>
        <h3 class="text-2xl font-serif font-bold text-primary mb-4">Serviços</h3>
        <p class="text-slate-600/90 mb-8 leading-relaxed font-light">
          Procedimentos ginecológicos minimamente invasivos e consultas especializadas em Goiânia.
        </p>
        <ul class="text-sm text-slate-600 mb-8 space-y-3">
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 rounded-full bg-secondary"></div>
            <span>Videolaparoscopia</span>
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 rounded-full bg-secondary"></div>
            <span>Histeroscopia</span>
          </li>
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 rounded-full bg-secondary"></div>
            <span>Avaliação Fetal</span>
          </li>
        </ul>
        <Button variant="primary" href="/servicos" class="w-full justify-center">
          Ver Serviços
        </Button>
      </div>
    </div>
  </div>
</section>
