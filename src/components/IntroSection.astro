---
---

<section class="py-24 lg:py-32 bg-white relative overflow-hidden">
  <div class="absolute -bottom-20 -left-20 w-96 h-96 bg-secondary/10 rounded-full blur-[100px] pointer-events-none"></div>
  <div class="absolute top-20 right-0 w-64 h-64 bg-accent/10 rounded-full blur-[80px] pointer-events-none"></div>
  
  <div class="container mx-auto px-6 lg:px-12 max-w-7xl relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">
      
      <!-- Text Content (Editorial Layout) -->
      <div class="lg:col-span-5 space-y-8 order-2 lg:order-1">
        <div>
          <h2 class="text-4xl lg:text-5xl font-serif font-bold text-primary leading-tight mb-6">
            Cuidado Integral<br class="hidden lg:block"/> da Saúde Feminina
          </h2>
          <div class="h-px bg-secondary/30 w-24"></div>
        </div>

        <div class="space-y-6 text-lg text-slate-600 font-light">
          <p class="text-xl font-normal text-primary/80 leading-relaxed">
            O atendimento com o <strong class="text-primary font-bold">Dr. Jony Barbosa</strong> vai além da consulta tradicional. Oferecemos cuidado personalizado e humanizado em todas as fases da vida.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 pt-4">
            <div class="space-y-3">
              <div class="w-8 h-8 rounded-full bg-secondary/10 flex items-center justify-center text-secondary mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
              </div>
              <h4 class="font-bold text-primary text-base">Ginecologia & Obstetrícia</h4>
              <p class="text-sm leading-relaxed">Acompanhamento realizado com atenção, sensibilidade e conhecimento técnico, da adolescência à melhor idade.</p>
            </div>
            <div class="space-y-3">
              <div class="w-8 h-8 rounded-full bg-secondary/10 flex items-center justify-center text-secondary mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <h4 class="font-bold text-primary text-base">Pré-natal Especializado</h4>
              <p class="text-sm leading-relaxed">Para gestantes, oferecemos pré-natal completo com exames de precisão e orientações claras.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Image Composition (Editorial Overlap) -->
      <div class="lg:col-span-7 relative order-1 lg:order-2 h-[500px] lg:h-[600px] w-full">
        <!-- Main Large Image -->
        <div class="absolute top-0 right-0 w-[85%] h-[85%] rounded-[2rem] overflow-hidden shadow-2xl bg-secondary/10 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" class="text-secondary/20" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          <div class="absolute inset-0 bg-primary/5 mix-blend-overlay"></div>
        </div>
        
        <!-- Overlapping Small Details -->
        <div class="absolute bottom-0 left-0 w-[50%] h-[45%] rounded-[2rem] overflow-hidden border-8 border-white shadow-xl z-20 hidden sm:flex items-center justify-center bg-primary transform -translate-y-8 translate-x-8">
           <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white/40">
             <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
           </svg>
        </div>
        
        <!-- Decorative Circle -->
        <div class="absolute top-12 left-12 w-24 h-24 rounded-full border border-secondary/30 border-dashed animate-spin-slow z-10"></div>
      </div>

    </div>
  </div>
</section>
